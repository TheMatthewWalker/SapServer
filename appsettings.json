{
  "SapPool": {
    "PoolSize": 0,
    "MaxQueueDepth": 50,
    "IdleTimeoutSeconds": 300,
    "HealthCheckIntervalSeconds": 60,
    "ReconnectDelayMs": 5000,
    "ServiceAccount": {
      "System": "",
      "Client": "",
      "SystemId": "",
      "User": "",
      "Password": "",
      "Language": "EN"
    }
  },
  "Auth": {
    "JwtSecret": "",
    "JwtIssuer": "sql2005-bridge",
    "JwtAudience": "sap-server",
    "SqlConnectionString": "",
    "PermissionCacheSeconds": 60
  },
  "AllowedOrigins": [],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/sap-server-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Urls": "https://localhost:7200;http://localhost:5200"
}
