### ZRFC_READ_TABLES – read LQUA stock
POST {{baseUrl}}/api/rfc/execute
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "functionName": "ZRFC_READ_TABLES",
  "importParameters": {
    "DELIMITER": "|",
    "ROWCOUNT": "10",
    "NO_DATA": " "
  },
  "inputTables": {
    "QUERY_TABLES": [
      { "TABNAME": "LQUA" }
    ]
  },
  "inputTablesItems": {
      "query_FIELDS": [
        { "TABNAME": "LQUA", "FIELDNAME": "MATNR" },
        { "TABNAME": "LQUA", "FIELDNAME": "CHARG" },
        { "TABNAME": "LQUA", "FIELDNAME": "VERME" }
      ]
  },
  "exportParameters": [],
  "outputTables": {
    "data_display":   ["WA"]
  }
}

###

### RFC_READ_TABLE – read USR01 (current user profile), no field filter
POST {{baseUrl}}/api/rfc/execute
Content-Type: application/json
Authorization: Bearer {{token}}

{
        "functionName": "L_TO_CREATE_SINGLE",
        "importParameters": {
          "I_LGNUM": "312", 
          "I_WERKS": "3012", 
          "I_LGORT": "1710",
          "I_SQUIT": "X",
          "I_BWLVS": "999",
          "I_MATNR": "000000000000010006",
          "I_ANFME": 10,
          "I_CHARG": "",
          "I_ZEUGN": "",
          "I_VLTYP": "RO",
          "I_VLPLA": "YARD",
          "I_BESTQ": "",
          "I_SOBKZ": "",
          "I_SONUM": "",
          "I_NLPLA": "YARD",
          "I_NLTYP": "RO"
        },
        "inputTables":      {},
        "inputTablesItems": {},
        "exportParameters": ["E_TANUM"],
        "outputTables":     { "RETURN": ["TYPE", "MESSAGE"] }
      }



